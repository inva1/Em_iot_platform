# ── IoT Platform Environment Configuration ──────────────────────────────────
# Copy this file to .env and customize as needed.
# docker-compose.yml reads these values automatically.

# ── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345
INFLUXDB_ORG=iot-platform
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_RETENTION=720h

# ── Broker ───────────────────────────────────────────────────────────────────
BROKER_HOST=0.0.0.0
BROKER_PORT=9000

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set STUB_AUTH=false when Peem's backend is ready
STUB_AUTH=true
AUTH_VERIFY_URL=http://localhost:8081/api/internal/verify-device

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
